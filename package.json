{
  "name": "portfolio_website",
  "version": "1.0.0",
  "description": "a website to show off some projects of mine",
  "main": "index.js",
  "engines": {
    "npm": ">=8.0.0",
    "node": ">=17.0.0"
  },
  "scripts": {
    "start": "concurrently --kill-others \"DEBUG=Eleventy* eleventy --serve\" \"npx @tailwindcss/cli -i src/css/tailwind.css -o public/css/style.css --watch\"",
    "build": "DEBUG=Eleventy* ELEVENTY_PRODUCTION=true eleventy && NODE_ENV=production npx @tailwindcss/cli -i src/css/tailwind.css -o public/css/style.css --minify"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dkulla01/portfolio_website.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/dkulla01/portfolio_website/issues"
  },
  "homepage": "https://github.com/dkulla01/portfolio_website#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@tailwindcss/cli": "^4.2.2",
    "concurrently": "^9.2.1",
    "html-minifier-next": "^5.2.2",
    "tailwindcss": "^4.2.2"
  }
}
